{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "warn"
  },
  "rules": {
    "eslint/no-unused-vars": "error",
    "no-console": "warn",
    "sort-imports": "off"
  }
}